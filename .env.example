# Neon Database Configuration
DATABASE_URL='Your Database URL'

# Gmail SMTP Configuration for Email Notifications
SMTP_HOST='Your SMTP Host'
SMTP_PORT='Your SMTP Port'
SMTP_USER='Your SMTP User'
SMTP_PASS='Your SMTP Password'

# Email Recipients
SALES_EMAIL='Your Sales Email'

# Next.js Configuration
NEXT_PUBLIC_SITE_URL='Your Site URL'

# Protects GET /api/contact, /api/booking, /api/newsletter (admin-style list endpoints).
# Use a long random string. Example: openssl rand -hex 32
ADMIN_API_SECRET=''

# Google Places API — powers the live Google reviews feed on /stories/guest-reviews
# 1) Create a key at https://console.cloud.google.com and enable "Places API"
# 2) Find your Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=''
GOOGLE_PLACE_ID=''
